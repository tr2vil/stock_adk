# ========================================
# Google Cloud / Vertex AI
# ========================================
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1
# Service account JSON (문자열 또는 파일 경로)
GOOGLE_KEY=

# ========================================
# Anthropic (Claude 모델 사용 시. LiteLLM 경유)
# ========================================
ANTHROPIC_API_KEY=

# ========================================
# Agent Models
# Gemini:  gemini-2.5-flash / gemini-2.5-pro
# Claude:  claude-opus-4-8 / claude-sonnet-4-6 / claude-haiku-4-5
#          (Claude 사용 시 ANTHROPIC_API_KEY 필요)
# ========================================
NEWS_AGENT_MODEL=gemini-2.5-flash
FUNDAMENTAL_AGENT_MODEL=gemini-2.5-flash
TECHNICAL_AGENT_MODEL=gemini-2.5-flash
EXPERT_AGENT_MODEL=gemini-2.5-flash
RISK_AGENT_MODEL=gemini-2.5-flash
ORCHESTRATOR_MODEL=gemini-2.5-pro

# ========================================
# Agent Hosts (Docker service names)
# ========================================
NEWS_AGENT_HOST=news-agent
NEWS_AGENT_PORT=8001
FUNDAMENTAL_AGENT_HOST=fundamental-agent
FUNDAMENTAL_AGENT_PORT=8002
TECHNICAL_AGENT_HOST=technical-agent
TECHNICAL_AGENT_PORT=8003
EXPERT_AGENT_HOST=expert-agent
EXPERT_AGENT_PORT=8004
RISK_AGENT_HOST=risk-agent
RISK_AGENT_PORT=8005
ORCHESTRATOR_PORT=8000
# Timeout for parallel sub-agent calls (seconds)
AGENT_CALL_TIMEOUT=90

# ========================================
# Toss Securities Open API
# ========================================
TOSS_API_KEY=          # client_id (tsck_live_...)
TOSS_SECRET_KEY=       # client_secret (tssk_live_...)
TOSS_ACCOUNT_SEQ=      # 선택: 비우면 /api/v1/accounts 첫 계좌 자동 사용

# ========================================
# Database
# ========================================
DATABASE_URL=postgresql://trading:password@postgres:5432/trading
DB_PASSWORD=password
REDIS_URL=redis://redis:6379/0

# ========================================
# Monitoring / Alerting
# ========================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SLACK_WEBHOOK_URL=
GRAFANA_PASSWORD=admin

# Log format: "console" (컬러 콘솔, 로컬 개발용) or "json" (Loki 수집용)
LOG_FORMAT=json

# ========================================
# Trading Limits
# ========================================
MAX_SINGLE_STOCK_RATIO=0.20
MAX_RISK_PER_TRADE=0.02
MAX_DAILY_TRADES=10
DRY_RUN=true
